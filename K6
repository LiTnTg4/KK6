local function find(container, name)
    return container:FindFirstChild(name) or container:FindFirstChild(name:gsub(" ", ""))
end

local function hideHead(c)
    local a = find(c, "Head")
    local b = find(c, "Face")
    if a and a.Transparency ~= 1 then a.Transparency = 1 end
    if b and b.Transparency ~= 1 then b.Transparency = 1 end
    if a then
        for _, v in a:GetChildren() do
            if v:IsA("Attachment") then v.Visible = false end
        end
    end
end

local function hideR6Legs(c)
    if not c then return end
    local u = find(c, "RightUpperLeg") or find(c, "Right Leg")
    local l = find(c, "RightLowerLeg")
    local o = find(c, "RightFoot") or find(c, "Right Foot")
    local function hide(p)
        if p and p.Transparency ~= 1 then
            p.Transparency = 1
            for _, v in p:GetChildren() do
                if v:IsA("Attachment") then v.Visible = false end
            end
        end
    end
    hide(u)
    hide(l)
    hide(o)
end

local function showR6Legs(c)
    if not c then return end
    local u = find(c, "RightUpperLeg") or find(c, "Right Leg")
    local l = find(c, "RightLowerLeg")
    local o = find(c, "RightFoot") or find(c, "Right Foot")
    if u then u.Transparency = 0 end
    if l then l.Transparency = 0 end
    if o then o.Transparency = 0 end
end

local dLeg = nil
local r6E = false
local r6S = false
getgenv().PhantomR6Leg = false

local function createLeg()
    if dLeg and dLeg.Parent then dLeg:Destroy() end
    dLeg = Instance.new("Part")
    dLeg.Name = "BrokenLeg"
    dLeg.Size = Vector3.new(0.832, 0.2496, 0.832)
    dLeg.BrickColor = BrickColor.new("Medium stone grey")
    dLeg.Material = Enum.Material.SmoothPlastic
    dLeg.Transparency = 0
    dLeg.Anchored = true
    dLeg.CanCollide = false
    dLeg.Parent = workspace
    local m = Instance.new("SpecialMesh")
    m.MeshId = "http://www.roblox.com/asset/?id=902942096"
    m.TextureId = "http://www.roblox.com/asset/?id=902843398"
    m.Scale = Vector3.new(0.936, 0.9984, 0.936)
    m.Parent = dLeg
end

local function enableR6(e)
    r6S = e
    r6E = e
    getgenv().PhantomR6Leg = e
    if e then
        if p.Character then
            createLeg()
            hideR6Legs(p.Character)
        end
    else
        if dLeg then dLeg:Destroy() dLeg = nil end
        if not getgenv().PhantomR15Leg then
            showR6Legs(p.Character)
        end
    end
end

local sR = {}
local r15S = false
getgenv().PhantomR15Leg = false

local function hideR15Legs(c)
    if not c then return end
    local m = c:FindFirstChildOfClass("Humanoid")
    if not m or m.RigType ~= Enum.HumanoidRigType.R15 then return end
    local u = find(c, "RightUpperLeg")
    if u then
        sR[u] = {MeshId = u.MeshId, TextureId = u.TextureID, Transparency = u.Transparency}
        u.MeshId = "http://www.roblox.com/asset/?id=902942096"
        u.TextureID = "http://www.roblox.com/asset/?id=902843398"
        u.Transparency = 0
    end
    local l = find(c, "RightLowerLeg")
    if l then
        sR[l] = {MeshId = l.MeshId, Transparency = l.Transparency}
        l.MeshId = "http://www.roblox.com/asset/?id=902942093"
        l.Transparency = 1
    end
    local o = find(c, "RightFoot") or find(c, "Right Foot")
    if o then
        sR[o] = {MeshId = o.MeshId, Transparency = o.Transparency}
        o.MeshId = "http://www.roblox.com/asset/?id=902942089"
        o.Transparency = 1
    end
end

local function showR15Legs(c)
    for p, s in pairs(sR) do
        if p and p.Parent then
            if s.MeshId ~= nil then pcall(function() p.MeshId = s.MeshId end) end
            if s.TextureId ~= nil then pcall(function() p.TextureID = s.TextureId end) end
            if s.Transparency ~= nil then p.Transparency = s.Transparency end
        end
    end
    sR = {}
end

local function enableR15(e)
    r15S = e
    getgenv().PhantomR15Leg = e
    if e then
        if p.Character then hideR15Legs(p.Character) end
    else
        if p.Character then showR15Legs(p.Character) end
    end
end

RunService.Heartbeat:Connect(function()
    if not r6E then
        if dLeg then dLeg.Transparency = 1 end
        return
    end
    local c = p.Character
    if not c then return end
    local u = find(c, "RightUpperLeg") or find(c, "Right Leg")
    if not u then return end
    if not dLeg or not dLeg.Parent then createLeg() end
    hideR6Legs(c)
    dLeg.CFrame = u.CFrame * CFrame.new(0, 0.7, 0)
end)

local function makeHeadless()
    local c = p.Character
    if not c then return end
    local head = find(c, "Head")
    if head then
        head.Transparency = 1
        head.CanCollide = false
        head.Massless = true
    end
    local face = find(c, "Face")
    if face then face:Destroy() end
    for _, obj in c:GetDescendants() do
        if obj:IsA("Decal") and obj.Name:lower():find("face") then obj:Destroy() end
        if obj:IsA("Texture") and obj.Name:lower():find("face") then obj:Destroy() end
    end
end

local headlessActive = true
task.spawn(function()
    while headlessActive do
        task.wait(1)
        local c = p.Character
        if c then
            local head = find(c, "Head")
            if head and head.Transparency ~= 1 then head.Transparency = 1 end
        end
    end
end)

local State = {Graphics = false, R6Leg = false, R15Leg = false, Hat = false}
local lastClean = 0
local graphicsMaterials = {}

local function enableGraphics(e)
    if e then
        State.Graphics = true
        graphicsMaterials = {}
        pcall(function()
            Lighting.GlobalShadows = false
            Lighting.FogEnabled = false
            for _, v in Lighting:GetChildren() do
                if v:IsA("PostEffect") then v.Enabled = false end
            end
        end)
        pcall(function()
            local u = UserSettings:GetService("UserGameSettings")
            u.GraphicsQuality = Enum.GraphicsQuality.Level01
            u.RenderScale = 0.2
            u.Shadows = false
            u.TextureQuality = Enum.TextureQuality.Level01
        end)
        for _, obj in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if obj:IsA("BasePart") and obj.Parent ~= p.Character then
                    if not graphicsMaterials[obj] then graphicsMaterials[obj] = obj.Material end
                    obj.Material = Enum.Material.Plastic
                end
                if obj:IsA("Texture") or obj:IsA("Decal") then obj:Destroy() end
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then obj:Destroy() end
            end)
        end
    else
        State.Graphics = false
        pcall(function()
            Lighting.GlobalShadows = true
            Lighting.FogEnabled = true
        end)
        pcall(function()
            local u = UserSettings:GetService("UserGameSettings")
            u.GraphicsQuality = Enum.GraphicsQuality.Automatic
            u.RenderScale = 1
            u.Shadows = true
            u.TextureQuality = Enum.TextureQuality.Automatic
        end)
        for obj, mat in pairs(graphicsMaterials) do
            pcall(function() if obj and obj.Parent then obj.Material = mat end end)
        end
        graphicsMaterials = {}
    end
end

RunService.Heartbeat:Connect(function()
    if State.Graphics then
        local t = tick()
        if t - lastClean >= 5 then
            pcall(function()
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then obj:Destroy() end
                end
            end)
            lastClean = t
        end
    end
end)

local function hideHat(e)
    local c = p.Character
    if not c then return end
    local kw = {"hair", "hat", "helmet", "cap", "hood", "headgear", "beanie", "visor", "accessory"}
    local t = e and 1 or 0
    for _, o in c:GetDescendants() do
        if o:IsA("BasePart") then
            local n = o.Name:lower()
            for _, k in ipairs(kw) do
                if n:find(k) then o.Transparency = t break end
            end
        end
        if o:IsA("Accessory") then
            local h = o:FindFirstChild("Handle")
            if h then h.Transparency = t end
        end
    end
    State.Hat = e
end

