-- 暴露接口到全局
myEnv.FFlagPermanent = {
    -- 手动设置图纸
    set = function(blueprints)
        if type(blueprints) == "table" then
            myEnv.activeBlueprints = blueprints
            executeBlueprints(blueprints)
            showNotification("FFlag 已更新", "新图纸已生效", 3)
        elseif type(blueprints) == "string" then
            local parsed, errors = parseBlueprints(blueprints)
            if parsed then
                myEnv.activeBlueprints = parsed
                executeBlueprints(parsed)
                showNotification("FFlag 已更新", "新图纸已生效", 3)
            else
                print("❌ 解析失败: " .. (errors and errors[1] or "未知错误"))
            end
        end
    end,
    
    -- 查看当前图纸
    list = function()
        if myEnv.activeBlueprints and next(myEnv.activeBlueprints) ~= nil then
            print("\n📋 当前存储的图纸：")
            for name, value in pairs(myEnv.activeBlueprints) do
                print("   " .. name .. " = " .. tostring(value))
            end
            print("")
        else
            print("📭 当前没有存储的图纸")
        end
    end,
    
    -- 清空图纸
    clear = function()
        myEnv.activeBlueprints = {}
        print("🗑️ 已清空所有图纸")
    end,
    
    -- 显示界面
    show = function()
        if myEnv._fflagInputUI then
            myEnv._fflagInputUI.Enabled = true
        else
            createInputUI()
        end
    end,
    
    -- 隐藏界面
    hide = function()
        if myEnv._fflagInputUI then
            myEnv._fflagInputUI.Enabled = false
        end
    end
}

