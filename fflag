--[[
FFlag 管理器（带实时反馈）
功能：设置 FFlag 时有通知提示
]]

local FFlagManager = {}

-- 初始化
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local FFLAG_FILE = "FFlagEditor.json"

-- 存储 FFlag
local fflags = {}

-- 加载保存的 FFlag
local function loadFFlags()
    if isfile and isfile(FFLAG_FILE) then
        pcall(function()
            fflags = HttpService:JSONDecode(readfile(FFLAG_FILE))
        end)
    end
end

-- 保存 FFlag
local function saveFFlags()
    if writefile then
        pcall(function()
            writefile(FFLAG_FILE, HttpService:JSONEncode(fflags))
        end)
    end
end

-- 显示通知
function FFlagManager:notify(text, duration, isError)
    duration = duration or 3
    local title = isError and "❌ FFlag 错误" or "✅ FFlag 成功"
    local icon = isError and "rbxasset://textures/ui/GuiImagePlaceholder.png" or "rbxasset://textures/ui/InspectMenu/Checkmark.png"
    
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = tostring(text),
            Duration = duration,
            Icon = icon
        })
    end)
    
    -- 同时在控制台输出
    print(string.format("[%s] %s", isError and "错误" or "成功", text))
end

-- 显示进度通知
function FFlagManager:notifyProgress(current, total, action)
    local percent = math.floor((current / total) * 100)
    self:notify(string.format("%s: %d/%d (%d%%)", action, current, total, percent), 1)
end

-- 加载已有配置
loadFFlags()
self:notify("已加载 " .. table.count(fflags) .. " 个 FFlag 配置", 2)

-- 设置单个 FFlag（带反馈）
function FFlagManager:set(name, value, silent)
    if not name then 
        if not silent then self:notify("FFlag 名称不能为空", 3, true) end
        return false 
    end
    
    local oldValue = self:get(name)
    local oldValueStr = oldValue ~= nil and tostring(oldValue) or "未设置"
    
    -- 保存到本地
    fflags[name] = value
    saveFFlags()
    
    -- 尝试应用 FFlag
    local success = false
    local method = ""
    
    -- 方法1: setfflag (最常用)
    pcall(function()
        if setfflag then
            setfflag(name, tostring(value))
            success = true
            method = "setfflag"
        end
    end)
    
    -- 方法2: sethiddenproperty
    if not success then
        pcall(function()
            if sethiddenproperty then
                local network = game:FindService("NetworkClient")
                if network then
                    sethiddenproperty(network, name, value)
                    success = true
                    method = "sethiddenproperty"
                end
            end
        end)
    end
    
    -- 反馈信息
    if not silent then
        if success then
            self:notify(string.format(
                "'%s' 已从 [%s] 改为 [%s] (使用 %s)",
                name,
                oldValueStr,
                tostring(value),
                method
            ), 4)
            
            -- 检查是否需要重进
            if name:find("Texture") or name:find("Render") or name:find("Terrain") then
                self:notify("⚠️ 此设置可能需要重进游戏才能完全生效", 4)
            end
        else
            self:notify(string.format("无法设置 FFlag '%s' = %s", name, tostring(value)), 4, true)
        end
    end
    
    return success
end

-- 批量设置 FFlag（带进度反馈）
function FFlagManager:setBatch(flags, presetName)
    local total = table.count(flags)
    local successCount = 0
    local failCount = 0
    local results = {}
    
    presetName = presetName or "批量"
    self:notify(string.format("开始应用 %s (%d 个 FFlag)", presetName, total), 3)
    
    local i = 0
    for name, value in pairs(flags) do
        i = i + 1
        self:notifyProgress(i, total, "正在应用")
        
        local success = self:set(name, value, true)  -- silent 模式
        results[name] = success
        if success then
            successCount = successCount + 1
        else
            failCount = failCount + 1
        end
        
        task.wait(0.1)  -- 避免通知太快
    end
    
    -- 最终结果
    if failCount == 0 then
        self:notify(string.format(
            "✅ %s 应用完成！全部 %d 个成功",
            presetName,
            successCount
        ), 5)
    else
        self:notify(string.format(
            "⚠️ %s 应用完成：%d 成功，%d 失败",
            presetName,
            successCount,
            failCount
        ), 5, failCount > 0)
    end
    
    return results
end

-- 获取 FFlag 值
function FFlagManager:get(name)
    -- 先从本地获取
    if fflags[name] ~= nil then
        return fflags[name]
    end
    
    -- 尝试从游戏获取
    local value = nil
    pcall(function()
        if getfflag then
            value = getfflag(name)
        elseif gethiddenproperty then
            local network = game:FindService("NetworkClient")
            if network then
                value = gethiddenproperty(network, name)
            end
        end
    end)
    
    return value
end

-- 删除 FFlag
function FFlagManager:remove(name)
    if not fflags[name] then
        self:notify("FFlag '" .. name .. "' 不存在", 3, true)
        return false
    end
    
    local oldValue = fflags[name]
    fflags[name] = nil
    saveFFlags()
    
    -- 尝试恢复默认
    pcall(function()
        if setfflag then
            setfflag(name, nil)
        end
    end)
    
    self:notify(string.format("已删除 FFlag '%s' (原值: %s)", name, tostring(oldValue)), 4)
    return true
end

-- 获取所有 FFlag
function FFlagManager:getAll()
    return fflags
end

-- 清空所有
function FFlagManager:clear()
    local count = table.count(fflags)
    fflags = {}
    saveFFlags()
    self:notify(string.format("已清空所有 %d 个 FFlag", count), 4)
end

