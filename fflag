-- 应用预设
function FFlagManager:applyPreset(name)
    local presetName = name:lower()
    local preset = self.PRESETS[presetName]
    
    if not preset then 
        self:notify("预设 '" .. name .. "' 不存在", 3, true)
        self:notify("可用预设: performance, graphics, network, hitreg, desync", 4)
        return false 
    end
    
    return self:setBatch(preset, presetName)
end

-- 列出所有 FFlag
function FFlagManager:list()
    local count = table.count(fflags)
    if count == 0 then
        self:notify("当前没有保存的 FFlag", 3)
        return
    end
    
    self:notify(string.format("当前有 %d 个 FFlag:", count), 3)
    for name, value in pairs(fflags) do
        print(string.format("  %s = %s", name, tostring(value)))
        task.wait(0.05)
    end
end

-- 获取 FFlag 状态
function FFlagManager:status(name)
    local value = self:get(name)
    if value ~= nil then
        self:notify(string.format("'%s' 当前值: %s", name, tostring(value)), 4)
    else
        self:notify(string.format("'%s' 未设置", name), 3, true)
    end
    return value
end

-- 加载已有配置
