--[[
    FFlag 花园会话永久生效版
    功能：执行一次脚本后，在当前花园会话（不关Roblox）中，
         无论换多少朵花（进多少个游戏），都自动按你的图纸施工
    要求：关闭花园（退Roblox）后失效，需要重新执行
]]

-- 获取环境
local env = getgenv or function() return _G end
local myEnv = env()

-- 存储当前会话的图纸（只在内存中，不存文件）
myEnv.activeBlueprints = myEnv.activeBlueprints or {}

-- 创建简单的提示界面（可选）
local function showNotification(title, text, duration)
    local success = pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 5
        })
    end)
    return success
end

-- 执行FFlag
local function executeBlueprints(blueprints)
    if not blueprints or next(blueprints) == nil then
        print("📭 没有图纸可执行")
        return 0
    end
    
    -- 尝试获取setfflag函数
    local setfflagFunc = setfflag or SetFFlag or function() end
    
    local successCount = 0
    local failCount = 0
    local results = {}
    
    for name, value in pairs(blueprints) do
        local success = pcall(function()
            setfflagFunc(name, tostring(value))
            successCount = successCount + 1
            table.insert(results, "✅ " .. name .. " = " .. tostring(value))
        end)
        
        if not success then
            failCount = failCount + 1
            table.insert(results, "❌ " .. name .. " = " .. tostring(value))
        end
    end
    
    -- 打印结果
    print("\n" .. string.rep("=", 50))
    print("📋 FFlag 执行结果（当前花园会话生效）")
    for _, result in ipairs(results) do
        print(result)
    end
    print(string.rep("-", 50))
    print("✅ 成功: " .. successCount .. " 张 | ❌ 失败: " .. failCount .. " 张")
    print("💡 只要不关闭Roblox，所有游戏都会按这些图纸施工")
    print(string.rep("=", 50) .. "\n")
    
    return successCount, failCount
end

-- 设置全局钩子，确保每次进游戏都自动应用
local function setupAutoApply()
    -- 如果已经设置过，就不再重复设置
    if myEnv._fflagAutoApplied then
        return
    end
    
    -- 标记已设置
    myEnv._fflagAutoApplied = true
    
    -- 监听游戏加载完成
    local function onGameLoaded()
        -- 每次进新游戏，自动应用存储的图纸
        if myEnv.activeBlueprints and next(myEnv.activeBlueprints) ~= nil then
            print("\n🔄 检测到新游戏，自动应用已存储的图纸...")
            executeBlueprints(myEnv.activeBlueprints)
            showNotification("FFlag 自动应用", "已按你的图纸施工", 3)
        end
    end
    
    -- 连接事件
    if game:GetService("Players").LocalPlayer then
        onGameLoaded()
    end
    
    game:GetService("Players").PlayerAdded:Connect(function()
        onGameLoaded()
    end)
    
    print("🔧 自动应用钩子已设置")
end

-- 解析输入的图纸文本
local function parseBlueprints(inputText)
    if not inputText or inputText:gsub("%s", "") == "" then
        return nil, "输入为空"
    end
    
    local blueprints = {}
    local errors = {}
    local lines = inputText:split("\n")
    
    for i, line in ipairs(lines) do
        -- 移除首尾空格，跳过空行和注释
        local trimmed = line:match("^%s*(.-)%s*$")
        if trimmed ~= "" and not trimmed:find("^//") and not trimmed:find("^--") then
            -- 支持格式：名字 = 值 或 名字:值
            local name, value = trimmed:match("([^=:]+)[=:](.+)")
            
            if name and value then
                -- 清理名字和值
                name = name:match("^%s*(.-)%s*$")
                value = value:match("^%s*(.-)%s*$")
                
                blueprints[name] = value
            else
                table.insert(errors, "第 " .. i .. " 行格式错误: " .. line)
            end
        end
    end
    
    if next(blueprints) == nil then
        return nil, "没有有效的FFlag格式"
    end
    
    return blueprints, errors
end

